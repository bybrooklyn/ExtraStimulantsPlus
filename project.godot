lights_and_shadows/positional_shadow/atlas_size=512
lights_and_shadows/max_lights_per_object=64

[shader_globals]

speed_intensity={
"type": "float",
"value": 0.0
}

[steam]

initialization/app_id=0
initialization/initialize_on_startup=false
initialization/embed_callbacks=false
multiplayer_peer/max_channels=4
