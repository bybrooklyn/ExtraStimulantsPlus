{
  "schema_version": 1,
  "id": "cool_mod",
  "name": "Cool Mod Example",
  "version": "0.1.0",
  "author": {
    "name": "bybrooklyn",
    "url": "https://github.com/bybrooklyn"
  },
  "description": "Minimal example mod for the ESP schema v1 loader, settings API, and hook API.",
  "required_framework_version": ">=0.0.2",
  "game_id": "sensory_overload",
  "game_versions": ">=0.13.0 <0.15.0",
  "tags": ["example", "utility"],
  "permissions": [],
  "dependencies": {},
